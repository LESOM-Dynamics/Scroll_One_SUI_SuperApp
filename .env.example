# Sui One SuperApp — Mobile (Expo)
# Copy to .env and customize. Only EXPO_PUBLIC_* vars are available in the app.

# Sui RPC endpoints
EXPO_PUBLIC_SUI_MAINNET_RPC_URL=https://fullnode.mainnet.sui.io:443
EXPO_PUBLIC_SUI_TESTNET_RPC_URL=https://fullnode.testnet.sui.io:443
EXPO_PUBLIC_SUI_DEVNET_RPC_URL=https://fullnode.devnet.sui.io:443

# Backend API (optional — use your machine LAN IP when testing on a physical device)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Walrus decentralized storage
EXPO_PUBLIC_WALRUS_PUBLISHER_TESTNET=https://publisher.walrus-testnet.walrus.space
EXPO_PUBLIC_WALRUS_AGGREGATOR_TESTNET=https://aggregator.walrus-testnet.walrus.space
EXPO_PUBLIC_WALRUS_AGGREGATOR_MAINNET=https://aggregator.walrus-mainnet.walrus.space
EXPO_PUBLIC_WALRUS_UPLOAD_RELAY_TESTNET=https://upload-relay.testnet.walrus.space
EXPO_PUBLIC_WALRUS_UPLOAD_RELAY_MAINNET=https://upload-relay.mainnet.walrus.space
# Optional: blob ID for mini-app manifest hosted on Walrus
EXPO_PUBLIC_WALRUS_MANIFEST_BLOB_ID=

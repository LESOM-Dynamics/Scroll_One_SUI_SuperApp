# Sui One SuperApp — Backend API
# Copy to .env and customize.

NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sui_one
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# Sui blockchain RPC
SUI_MAINNET_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_TESTNET_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_DEVNET_RPC_URL=https://fullnode.devnet.sui.io:443

# External APIs (optional)
COINGECKO_API_KEY=
IPFS_GATEWAY=https://ipfs.io/ipfs/

# CORS (comma-separated origins — include Expo dev server and landing page)
CORS_ORIGIN=http://localhost:3000,http://localhost:8081,http://localhost:3001
